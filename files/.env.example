# TfL API
TFL_APP_KEY=your_tfl_app_key_here

# OpenWeather API
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Google Maps Platform — optional paid upgrade (Places API New)
# Leave empty for free Photon search (~0.3 s).
GOOGLE_MAPS_API_KEY=

# App
APP_ENV=development
